# Standard Android .gitignore

# Built objects
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx

# Specific build directories
/app/build/
/alx-core-pdf/build/

# IDE and Environment
.idea/
*.iws
*.ipr

# OS generated files
Thumbs.db
db.lock

# Log files
*.log

# Mobile specific
*.apk
*.ap_
*.dex
